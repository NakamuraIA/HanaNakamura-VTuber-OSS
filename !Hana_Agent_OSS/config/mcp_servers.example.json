{
  "version": 1,
  "servers": [
    {
      "id": "filesystem",
      "name": "Filesystem Dev Local",
      "enabled": false,
      "command": "cmd",
      "args": ["/c", "npx", "-y", "@modelcontextprotocol/server-filesystem", "E:\\Projeto_Hana_AI"],
      "env": {},
      "cwd": "E:\\Projeto_Hana_AI",
      "timeout": 20,
      "allowed_tools": []
    },
    {
      "id": "git",
      "name": "Git Dev Local",
      "enabled": false,
      "command": "uvx",
      "args": ["mcp-server-git", "--repository", "E:\\Projeto_Hana_AI"],
      "env": {},
      "cwd": "E:\\Projeto_Hana_AI",
      "timeout": 20,
      "allowed_tools": []
    },
    {
      "id": "tavily",
      "name": "Tavily Web Search",
      "enabled": false,
      "command": "cmd",
      "args": ["/c", "npx", "-y", "tavily-mcp@0.1.3"],
      "env": {
        "TAVILY_API_KEY": "${TAVILY_API_KEY}"
      },
      "cwd": "E:\\Projeto_Hana_AI",
      "timeout": 30,
      "allowed_tools": ["tavily-search"]
    }
  ]
}
