# ========================================
# .env.example - Hana Agent OSS
# ========================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env na raiz do projeto.
# 2. Preencha APENAS as chaves que você usa.
# 3. NUNCA commite o arquivo .env real (ele contém segredos).
# 4. O backend carrega primeiro o .env da raiz do projeto usando python-dotenv.
#    Arquivos .env opcionais dentro de !Hana_Agent_OSS/ continuam locais/privados.
# 5. Algumas variáveis também podem ser definidas diretamente no sistema
#    (setx no Windows ou export no Linux) ou no painel de Configurações.
#
# IMPORTANTE (seguindo regras do projeto):
# - LLM, STT e TTS são providers SEPARADOS. Não misture chaves.
# - Minimax, Cartesia, Azure etc. foram adicionados como providers TTS opcionais.
# - Use o painel "Conexões" para ativar/desativar providers em runtime.
#
# ========================================
# LLM / CORE PROVIDERS
# ========================================

# Gemini API (Google AI Studio) - LLM principal recomendado
# Chave começa com AIza...
GEMINI_API_KEY=sua_chave_aqui

# Groq (LLM + STT Whisper-large-v3)
# Usado por provider LLM "groq" e STT "groq_whisper".
GROQ_API_KEY=sua_chave_groq_aqui

# OpenRouter (LLM alternativo, bom quando Gemini quota acaba)
# Usado SOMENTE pelo provider LLM openrouter. Não afeta STT/TTS.
OPENROUTER_API_KEY=sua_chave_openrouter_aqui
OPENROUTER_SITE_URL=https://github.com/NakamuraIA/HanaNakamura-VTuber-OSS
OPENROUTER_APP_NAME=Hana Nakamura VTuber OSS

# ========================================
# DEEPSEEK (oficial, api.deepseek.com)
# ========================================
# Chave da API oficial do DeepSeek (modelos deepseek-v4-flash / deepseek-v4-pro).
# Obtenha em https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sua_chave_deepseek_aqui

# ========================================
# TTS PROVIDERS (separados do LLM)
# ========================================

# Google Cloud TTS (alta qualidade, latência boa, várias vozes pt-BR nativas)
# Recomendado para qualidade "igual Google Cloud".
# Esta chave deve ser restrita apenas à API Text-to-Speech.
GOOGLE_CLOUD_TTS_API_KEY=sua_chave_tts_aqui

# Opcional: necessário para streaming Cloud TTS (Chirp3 etc.) via ADC
GOOGLE_APPLICATION_CREDENTIALS=C:\caminho\para\service-account.json

# Cartesia (Sonic) - ultra baixa latência (~40-90ms), barata, boa para voz em tempo real
# Use vozes nativas pt-BR do playground (filter Brazilian Portuguese + Female).
# Ex: Luana, Ana Paula, Beatriz, Isabella etc.
CARTESIA_API_KEY=sk_car_sua_chave_aqui

# Minimax TTS (T2A v2) - boa qualidade, suporte forte a Português BR
# Muitas vozes femininas nativas (Portuguese_ConfidentWoman, LovelyLady etc.)
# Modelos recomendados: speech-2.8-turbo (latência) ou speech-2.8-hd
# Chave começa com sk-api-...
# Adicionado para testar vozes BR de alta qualidade + preço competitivo.
MINIMAX_API_KEY=sk-api-sua_chave_minimax_aqui

# ElevenLabs TTS - voz configurada por ID da biblioteca do usuario.
# Modelo de baixa latencia: eleven_flash_v2_5. Outras opcoes:
# eleven_turbo_v2_5, eleven_multilingual_v2 e eleven_v3.
# Chave obtida em: https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_sua_chave_elevenlabs_aqui

# Azure Neural TTS (ótimas vozes nativas BR: Francisca, Thalita etc.)
# Mesma família das vozes Edge, mas com mais controle e qualidade cloud.
AZURE_SPEECH_KEY=sua_chave_azure_aqui
AZURE_REGION=brazilsouth


# OpenAI (opcional para integracoes/futuros providers que usem OpenAI)
OPENAI_API_KEY=sua_chave_openai_aqui

# ========================================
# DISCORD (opcional)
# ========================================
DISCORD_TOKEN=seu_token_do_bot_aqui
HANA_BACKEND_URL=http://127.0.0.1:8042

# ========================================
# MCP / WEB SEARCH
# ========================================
# Tavily (MCP server para pesquisa web)
TAVILY_API_KEY=sua_chave_tavily_aqui

# ========================================
# OUTRAS VARIÁVEIS HANA (opcionais)
# ========================================
# HANA_STT_MAX_UPLOAD_MB=25
# HANA_BACKEND_HOST=127.0.0.1
# HANA_BACKEND_PORT=8042
# HANA_WS_MAX_SIZE=67108864
# HANA_MEMORY_DB=runtime/hana_memory.sqlite3
# HANA_MEMORY_SEMANTIC=0
# HANA_MEMORY_EMBED_MODEL=intfloat/multilingual-e5-small
# HANA_MEMORY_EMBED_LAZY=1
# HANA_SKILLS_DIR= (pasta de skills custom)

# ========================================
# LEGADO / OUTROS (manter por compatibilidade)
# ========================================
# Algumas variáveis antigas ainda são lidas em partes legadas.
# OPENAI_API_KEY ja listado acima para integracoes opcionais.

# Fim do .env.example
# Lembre-se: copie para .env e preencha apenas o que usar.
